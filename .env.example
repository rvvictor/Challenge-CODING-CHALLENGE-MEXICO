# Aurelion environment template. Copy to `.env` and adjust as needed.
# Every value here has a safe default in backend/app/core/config.py; nothing is
# required to run the demo. Do NOT commit a real .env or any exchange keys.

# --- Runtime ---------------------------------------------------------------
PORT=8000
HOST=0.0.0.0
MARKET_MODE=demo            # demo | auto | live  (demo is the reliable evaluation path)
EXCHANGE_PROFILE=speed      # speed | demo | coverage
ACTIVE_EXCHANGES=           # comma list, or "all" for the full catalog
AUTO_EXECUTION=true

# --- Security (recommended for any public/production deployment) ------------
# When CONTROL_TOKEN is set, every mutating endpoint (/api/control, /api/params,
# /api/reset) must send a matching `X-Aurelion-Token` header. Empty = open
# (convenient for a local or judge-facing demo dashboard).
CONTROL_TOKEN=
# Comma-separated CORS allowlist, or "*" for any origin (no credentials are used).
ALLOWED_ORIGINS=*

# --- AI co-pilot (optional; narration only, never executes trades) ----------
# If unset, the dashboard shows a deterministic explanation instead.
ANTHROPIC_API_KEY=

# --- Engine cadence & sizing ----------------------------------------------
EVALUATION_INTERVAL_MS=450
ORDER_BOOK_LIMIT=20
MIN_TRADE_BTC=0.002
MAX_TRADE_BTC=0.015
MIN_NET_BPS=0.75
MIN_NET_PROFIT_USD=0.2
MIN_CONFIDENCE=0.42

# --- Triangular / cycles ---------------------------------------------------
TRIANGULAR_ENABLED=true
TRIANGULAR_QUOTE_SIZE=650

# --- Risk & circuit breaker ------------------------------------------------
MAX_VOLATILITY_PCT=2.4
VOLATILITY_MIN_SAMPLES=8
RISK_BUDGET_HOUR_USD=75
PAUSE_AFTER_LOSS_MS=60000

# --- Optional infrastructure ----------------------------------------------
REDIS_URL=                 # enables Redis Pub/Sub when set
DATABASE_URL=              # Postgres for durable audit; SQLite fallback otherwise
PERSISTENCE_ENABLED=true
SQLITE_PATH=.aurelion/aurelion.db
