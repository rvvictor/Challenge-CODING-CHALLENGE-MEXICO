# Aurelion environment template. Copy to `.env` and adjust as needed.
# Every value here has a safe default in backend/app/core/config.py; nothing is
# required to run the demo. Do NOT commit a real .env or any exchange keys.

# --- Runtime ---------------------------------------------------------------
PORT=8000
HOST=0.0.0.0
MARKET_MODE=demo            # demo | auto | live  (demo is the reliable evaluation path)
EXCHANGE_PROFILE=speed      # speed | demo | coverage
ACTIVE_EXCHANGES=           # comma list, or "all" for the full catalog
AUTO_EXECUTION=true

# --- Security (recommended for any public/production deployment) ------------
# When CONTROL_TOKEN is set, every mutating endpoint (/api/control, /api/params,
# /api/reset) must send a matching `X-Aurelion-Token` header. Empty = open
# (convenient for a local or judge-facing demo dashboard).
CONTROL_TOKEN=
# Comma-separated CORS allowlist, or "*" for any origin (no credentials are used).
ALLOWED_ORIGINS=*
# Sliding-window rate limit for mutating endpoints (requests / 10 s per client;
# 0 disables). Protects the control surface from accidental or hostile floods.
CONTROL_RATE_LIMIT=60

# --- AI co-pilot (optional; narration only, never executes trades) ----------
# If unset, the dashboard shows a deterministic explanation instead.
ANTHROPIC_API_KEY=
NARRATOR_MODEL=claude-haiku-4-5-20251001

# --- Engine cadence & sizing ----------------------------------------------
EVALUATION_INTERVAL_MS=450
ORDER_BOOK_LIMIT=20
MIN_TRADE_BTC=0.002
MAX_TRADE_BTC=0.015
MIN_NET_BPS=0.75
MIN_NET_PROFIT_USD=0.2
MIN_CONFIDENCE=0.42

# --- Triangular / cycles ---------------------------------------------------
TRIANGULAR_ENABLED=true
TRIANGULAR_QUOTE_SIZE=650

# --- Risk & circuit breaker ------------------------------------------------
MAX_VOLATILITY_PCT=2.4
VOLATILITY_MIN_SAMPLES=8
RISK_BUDGET_HOUR_USD=75
PAUSE_AFTER_LOSS_MS=60000

# --- Live-feed sanitizer (feed guard) --------------------------------------
# Rejects poisoned live order books (non-finite prices, crossed books, fat-finger
# jumps) at the provider boundary. Demo books are generated internally and bypass.
FEED_GUARD_ENABLED=true
FEED_MAX_JUMP_PCT=8.0       # max mid move between updates before a book is rejected

# --- Wide-net discovery lane (scout) ---------------------------------------
# Background sweep of the FULL venue universe + XRP/LTC/SOL/AVAX from batched
# public tickers, off the hot loop (does not affect decision latency).
DISCOVERY_ENABLED=true
DISCOVERY_INTERVAL_MS=45000 # sweep cadence
DISCOVERY_MIN_PERSISTENCE=3 # consecutive sweeps a route must hold to be "promotable"
DISCOVERY_MIN_NET_BPS=0.0   # edge threshold for building a persistence streak

# --- Testnet execution (sandbox, FAKE money; no real capital ever) ---------
# Real orders fire ONLY when this is 1 AND trading-only testnet keys are set
# below. This drives exchange TESTNETS/sandboxes, never mainnet. Mainnet
# real-money trading is intentionally not implemented. NEVER use a key with
# withdrawal permission. Do not commit a real .env (.env* is gitignored).
AURELION_ENABLE_LIVE=0
TESTNET_MAX_ORDER_USD=500
# Trading-only sandbox credentials, e.g. from testnet.binance.vision / Bybit testnet:
# TESTNET_BINANCE_KEY=
# TESTNET_BINANCE_SECRET=
# TESTNET_BYBIT_KEY=
# TESTNET_BYBIT_SECRET=

# --- Optional infrastructure ----------------------------------------------
REDIS_URL=                 # enables Redis Pub/Sub when set
DATABASE_URL=              # Postgres for durable audit; SQLite fallback otherwise
PERSISTENCE_ENABLED=true
SQLITE_PATH=.aurelion/aurelion.db
